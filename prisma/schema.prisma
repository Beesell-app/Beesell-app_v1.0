  posting_frequency   String?
  content_types       Json?     @default("[]")
  tenants             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, platform], map: "platform_connections_tenant_platform_key")
  @@index([status])
  @@index([deleted_at])
  @@index([platform])
  @@index([tenant_id])
  @@index([token_expires_at])
  @@map("platform_connections")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ab_tests {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String         @db.Uuid
  campaign_id        String         @db.Uuid
  name               String         @db.VarChar(255)
  status             String         @default("running") @db.VarChar(20)
  variable_type      String         @db.VarChar(30)
  traffic_split      Int            @default(50) @db.SmallInt
  confidence_level   Decimal        @default(95.00) @db.Decimal(5, 2)
  min_conversions    Int            @default(50)
  min_days           Int            @default(7) @db.SmallInt
  winner_variant     String?        @db.VarChar(10)
  confidence_reached Decimal?       @db.Decimal(5, 2)
  significance_at    DateTime?      @db.Timestamptz(6)
  summary            Json           @default("{}")
  started_at         DateTime?      @db.Timestamptz(6)
  ended_at           DateTime?      @db.Timestamptz(6)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime       @default(now()) @db.Timestamptz(6)
  ad_campaigns       ad_campaigns   @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants            Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ad_creatives       ad_creatives[]

  @@index([campaign_id], map: "idx_ab_tests_campaign")
  @@schema("public")
}

