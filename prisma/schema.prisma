generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model Tenant {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                   @db.VarChar(255)
  slug                    String                   @unique @db.VarChar(100)
  plan                    String                   @default("free")
  plan_seats              Int                      @default(1) @db.SmallInt
  trial_ends_at           DateTime?                @db.Timestamptz(6)
  is_active               Boolean                  @default(true)
  timezone                String                   @default("Asia/Jakarta") @db.VarChar(50)
  locale                  String                   @default("id-ID") @db.VarChar(10)
  quota_content_used      Int                      @default(0)
  quota_content_max       Int                      @default(50)
  quota_video_used        Int                      @default(0)
  quota_video_max         Int                      @default(5)
  quota_bulk_used         Int                      @default(0)
  quota_bulk_max          Int                      @default(0)
  settings                Json                     @default("{}")
  metadata                Json                     @default("{}")
  created_at              DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                 @default(now()) @db.Timestamptz(6)
  deleted_at              DateTime?                @db.Timestamptz(6)
  owner_name              String?
  whatsapp                String?
  seller_type             seller_type?
  niche                   String?
  sub_niche               String?
  product_count           String?
  monthly_revenue         String?
  business_scale          String?
  main_goals              String[]                 @default([])
  billing_cycle           billing_cycle            @default(monthly)
  quota_platform_max      Int                      @default(3)
  quota_seats_max         Int                      @default(1)
  quota_reset_at          DateTime                 @default(dbgenerated("(date_trunc('month'::text, now()) + '1 mon'::interval)")) @db.Timestamptz(6)
  plan_expires_at         DateTime?                @db.Timestamptz(6)
  stripe_customer_id      String?                  @db.VarChar(100)
  stripe_subscription_id  String?                  @db.VarChar(100)
  image_credits_used      Int?                     @default(0)
  image_credits_max       Int?                     @default(5)
  upscale_credits_used    Int?                     @default(0)
  upscale_credits_max     Int?                     @default(0)
  ai_memory               Json                     @default("{}")
  primary_platform        String?                  @db.VarChar(50)
  onboarding_completed_at DateTime?                @db.Timestamptz(6)
  ab_tests                ab_tests[]
  ad_campaigns            ad_campaigns[]
  ad_creatives            ad_creatives[]
  ad_sets                 ad_sets[]
  affiliate_links         affiliate_links[]
  ai_jobs                 AiJob[]
  api_logs                api_logs[]
  audit_logs              audit_logs[]
  billing_events          billing_events[]
  brand_kits              BrandKit[]
  brand_profiles          brand_profiles[]
  bulk_batches            bulk_batches[]
  calendar_events         calendar_events[]
  collaboration_deals     collaboration_deals[]
  content_folders         content_folders[]
  content_templates       content_templates[]
  contents                Content[]
  custom_audiences        custom_audiences[]
  feedback                feedback[]
  folders                 Folder[]
  generation_credits_log  generation_credits_log[]
  image_generations       image_generations[]
  image_results           image_results[]
  invite_redemptions      invite_redemptions[]
  invoices                invoices[]
  notifications           notifications[]
  nps_responses           nps_responses[]
  onboarding_progress     onboarding_progress?
  payment_transactions    payment_transactions[]
  platform_connections    PlatformConnection[]
  posting_rules           posting_rules[]
  prompt_histories        prompt_histories[]
  quota_overrides         quota_overrides?
  scheduled_posts         scheduled_posts[]
  subscriptions           subscriptions[]
  users                   User[]
  video_jobs              video_jobs[]

  @@index([is_active, created_at(sort: Desc)], map: "idx_tenants_active")
  @@index([plan_expires_at], map: "idx_tenants_plan_expires")
  @@index([slug], map: "idx_tenants_slug")
  @@index([ai_memory], map: "idx_tenants_ai_memory", type: Gin)
  @@map("tenants")
  @@schema("public")
}

model User {
  id                                                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                                          String                   @db.Uuid
  email                                              String                   @unique @db.VarChar(255)
  email_verified_at                                  DateTime?                @db.Timestamptz(6)
  password_hash                                      String?                  @db.VarChar(255)
  name                                               String                   @default("") @db.VarChar(255)
  avatar_url                                         String?
  role                                               user_role                @default(owner)
  is_active                                          Boolean                  @default(true)
  oauth_provider                                     oauth_provider?
  oauth_id                                           String?                  @db.VarChar(255)
  oauth_token                                        String?
  mfa_enabled                                        Boolean                  @default(false)
  mfa_secret                                         String?                  @db.VarChar(100)
  last_login_at                                      DateTime?                @db.Timestamptz(6)
  last_login_ip                                      String?                  @db.Inet
  login_count                                        Int                      @default(0)
  failed_login_count                                 Int                      @default(0) @db.SmallInt
  locked_until                                       DateTime?                @db.Timestamptz(6)
  onboarding_step                                    Int                      @default(0) @db.SmallInt
  onboarding_done                                    Boolean                  @default(false)
  preferences                                        Json                     @default("{}")
  metadata                                           Json                     @default("{}")
  created_at                                         DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                                         DateTime                 @default(now()) @db.Timestamptz(6)
  deleted_at                                         DateTime?                @db.Timestamptz(6)
  ad_campaigns                                       ad_campaigns[]
  affiliate_links                                    affiliate_links[]
  ai_jobs                                            AiJob[]
  api_logs                                           api_logs[]
  audit_logs                                         audit_logs[]
  bulk_batches                                       bulk_batches[]
  collaboration_deals                                collaboration_deals[]
  content_folders_content_folders_created_byTousers  content_folders[]        @relation("content_folders_created_byTousers")
  content_folders_content_folders_user_idTousers     content_folders[]        @relation("content_folders_user_idTousers")
  content_templates                                  content_templates[]
  contents                                           Content[]
  email_verifications                                email_verifications[]
  generation_credits_log                             generation_credits_log[]
  image_generations                                  image_generations[]
  notifications                                      notifications[]
  platform_connections                               PlatformConnection[]
  refresh_tokens                                     refresh_tokens[]
  scheduled_posts_scheduled_posts_approved_byTousers scheduled_posts[]        @relation("scheduled_posts_approved_byTousers")
  scheduled_posts_scheduled_posts_user_idTousers     scheduled_posts[]        @relation("scheduled_posts_user_idTousers")
  tenants                                            Tenant                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("users")
  @@schema("public")
}

model Folder {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @map("tenant_id") @db.Uuid
  parentId   String?  @map("parent_id") @db.Uuid
  name       String
  color      String   @default("#94A3B8")
  sortOrder  Int      @default(0) @map("sort_order")
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent     Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  children   Folder[] @relation("FolderHierarchy")
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, parentId, name])
  @@index([tenant_id, parentId, sortOrder], map: "idx_folders_tenant_parent")
  @@map("folders")
  @@schema("public")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Content {
  id                                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                            String                   @db.Uuid
  user_id                              String?                  @db.Uuid
  type                                 content_type
  status                               content_status           @default(draft)
  title                                String?                  @db.VarChar(500)
  caption_text                         String?
  caption_variants                     Json                     @default("[]")
  hashtags                             String[]                 @default([])
  s3_key                               String?
  cdn_url                              String?
  thumbnail_s3_key                     String?
  thumbnail_cdn_url                    String?
  file_size_bytes                      BigInt?
  mime_type                            String?                  @db.VarChar(100)
  width_px                             Int?
  height_px                            Int?
  duration_sec                         Decimal?                 @db.Decimal(8, 2)
  platforms                            platform_type[]          @default([instagram])
  product_url                          String?
  product_data                         Json                     @default("{}")
  template_id                          String?                  @db.Uuid
  brand_kit_id                         String?                  @db.Uuid
  generation_config                    Json                     @default("{}")
  ai_model                             String?                  @db.VarChar(100)
  ai_provider                          String?                  @db.VarChar(50)
  ai_prompt_hash                       String?                  @db.VarChar(64)
  generation_cost_usd                  Decimal?                 @db.Decimal(10, 6)
  bulk_job_id                          String?                  @db.Uuid
  bulk_row_index                       Int?
  rating                               Int?                     @db.SmallInt
  user_feedback                        String?
  tags                                 String[]                 @default([])
  folder_id                            String?                  @db.Uuid
  is_starred                           Boolean                  @default(false)
  is_deleted                           Boolean                  @default(false)
  deleted_at                           DateTime?                @db.Timestamptz(6)
  total_reach                          Int                      @default(0)
  total_engagement                     Int                      @default(0)
  total_clicks                         Int                      @default(0)
  total_conversions                    Int                      @default(0)
  last_analytics_sync                  DateTime?                @db.Timestamptz(6)
  created_at                           DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime                 @default(now()) @db.Timestamptz(6)
  media_url                            String?
  media_s3_key                         String?
  thumbnail_url                        String?
  primary_platform                     platform_type?           @default(instagram)
  ai_job_id                            String?                  @db.Uuid
  cost_usd                             Decimal?                 @db.Decimal(10, 6)
  search_vector                        Unsupported("tsvector")?
  ad_creatives                         ad_creatives[]
  ai_jobs_ai_jobs_content_idTocontents AiJob[]                  @relation("ai_jobs_content_idTocontents")
  calendar_events                      calendar_events[]
  ai_jobs_contents_ai_job_idToai_jobs  AiJob?                   @relation("contents_ai_job_idToai_jobs", fields: [ai_job_id], references: [id], onUpdate: NoAction)
  brand_kits                           BrandKit?                @relation(fields: [brand_kit_id], references: [id], onUpdate: NoAction)
  content_templates                    content_templates?       @relation(fields: [template_id], references: [id], onUpdate: NoAction)
  tenants                              Tenant                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                                User?                    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  content_folders                      content_folders?         @relation(fields: [folder_id], references: [id], onUpdate: NoAction, map: "fk_contents_folder")
  image_results                        image_results[]
  scheduled_posts                      scheduled_posts[]
  video_jobs                           video_jobs[]

  @@index([search_vector], type: Gin)
  @@map("contents")
  @@schema("public")
}

model AiJob {
  id                                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                             String     @db.Uuid
  user_id                               String?    @db.Uuid
  job_type                              job_type
  status                                job_status @default(pending)
  priority                              Int        @default(5) @db.SmallInt
  queue_name                            String?    @db.VarChar(100)
  bullmq_job_id                         String?    @db.VarChar(255)
  worker_id                             String?    @db.VarChar(100)
  attempt_count                         Int        @default(0) @db.SmallInt
  max_attempts                          Int        @default(3) @db.SmallInt
  input_params                          Json       @default("{}")
  output_data                           Json       @default("{}")
  error_data                            Json       @default("{}")
  queued_at                             DateTime?  @db.Timestamptz(6)
  started_at                            DateTime?  @db.Timestamptz(6)
  completed_at                          DateTime?  @db.Timestamptz(6)
  duration_ms                           Int?
  cost_usd                              Decimal    @default(0) @db.Decimal(10, 6)
  tokens_used                           Int?
  total_items                           Int?
  completed_items                       Int        @default(0)
  failed_items                          Int        @default(0)
  progress_pct                          Int        @default(0) @db.SmallInt
  created_at                            DateTime   @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime   @default(now()) @db.Timestamptz(6)
  input_data                            Json       @default("{}")
  error_message                         String?
  attempts                              Int        @default(0) @db.SmallInt
  provider                              String?
  model                                 String?
  prompt_hash                           String?
  cached                                Boolean    @default(false)
  content_id                            String?    @db.Uuid
  bulk_batch_id                         String?    @db.Uuid
  bulk_row_index                        Int?
  prediction_id                         String?    @db.VarChar(200)
  error_code                            String?    @db.VarChar(100)
  retry_count                           Int        @default(0)
  tenants                               Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                                 User?      @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  contents_ai_jobs_content_idTocontents Content?   @relation("ai_jobs_content_idTocontents", fields: [content_id], references: [id], onUpdate: NoAction, map: "fk_ai_jobs_content")
  contents_contents_ai_job_idToai_jobs  Content[]  @relation("contents_ai_job_idToai_jobs")

  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([job_type])
  @@index([prediction_id])
  @@index([prompt_hash])
  @@index([tenant_id])
  @@index([user_id])
  @@index([tenant_id, status, created_at(sort: Desc)], map: "idx_ai_jobs_tenant_status")
  @@index([tenant_id, job_type, created_at(sort: Desc)], map: "idx_ai_jobs_tenant_type")
  @@index([tenant_id, status, created_at(sort: Desc)], map: "idx_jobs_tenant_status")
  @@map("ai_jobs")
  @@schema("public")
}

model BrandKit {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String    @db.Uuid
  name                String    @default("Default") @db.VarChar(100)
  is_default          Boolean   @default(false)
  logo_url            String?
  logo_s3_key         String?
  color_primary       String?   @db.VarChar(7)
  color_secondary     String?   @db.VarChar(7)
  color_accent        String?   @db.VarChar(7)
  color_bg            String    @default("#FFFFFF") @db.VarChar(7)
  color_text          String    @default("#111827") @db.VarChar(7)
  font_heading        String    @default("Arial") @db.VarChar(100)
  font_body           String    @default("Arial") @db.VarChar(100)
  watermark_url       String?
  watermark_s3_key    String?
  watermark_opacity   Decimal   @default(0.50) @db.Decimal(3, 2)
  watermark_position  String    @default("bottom_right") @db.VarChar(20)
  brand_voice_summary String?
  brand_keywords      String[]
  brand_forbidden     String[]
  metadata            Json      @default("{}")
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  description         String?
  logo_storage_path   String?   @db.VarChar(500)
  primary_color       String    @default("#2563EB") @db.VarChar(7)
  secondary_color     String    @default("#1D4ED8") @db.VarChar(7)
  accent_color        String    @default("#FFE600") @db.VarChar(7)
  bg_color            String    @default("#FFFFFF") @db.VarChar(7)
  text_color          String    @default("#0F172A") @db.VarChar(7)
  primary_font        String    @default("DM Sans") @db.VarChar(100)
  secondary_font      String    @default("Fraunces") @db.VarChar(100)
  default_tone        String    @default("casual") @db.VarChar(50)
  default_language    String    @default("indonesian_casual") @db.VarChar(50)
  avoid_words         String?
  is_active           Boolean   @default(true)
  deleted_at          DateTime? @db.Timestamptz(6)
  tenants             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  contents            Content[]

  @@index([deleted_at])
  @@index([tenant_id, is_default], map: "brand_kits_tenant_default_idx")
  @@index([tenant_id])
  @@index([tenant_id], map: "idx_brand_kits_tenant")
  @@map("brand_kits")
  @@schema("public")
}

model PlatformConnection {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String    @db.Uuid
  user_id             String    @db.Uuid
  platform_account_id String    @db.VarChar(255)
  platform_username   String?   @db.VarChar(255)
  platform_name       String?   @db.VarChar(255)
  platform_avatar_url String?
  platform_type       String?   @db.VarChar(50)
  follower_count      Int?
  access_token        String
  refresh_token       String?
  token_expires_at    DateTime? @db.Timestamptz(6)
  token_scope         String[]
  is_active           Boolean   @default(true)
  last_used_at        DateTime? @db.Timestamptz(6)
  last_verified_at    DateTime? @db.Timestamptz(6)
  platform_metadata   Json      @default("{}")
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  platform            String?   @db.VarChar(50)
  account_id          String?   @db.VarChar(200)
  account_name        String?   @db.VarChar(200)
  account_avatar      String?
  scope               String?
  status              String    @default("disconnected") @db.VarChar(30)
  error_message       String?
  error_code          String?   @db.VarChar(100)
